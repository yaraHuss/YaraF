# Firebase project config — get these from Firebase Console > Project Settings
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# WhatsApp number in international format, no + or spaces (e.g. 9715xxxxxxx)
VITE_WHATSAPP_NUMBER=

# Calendly scheduling link
VITE_CALENDLY_URL=

# AI chatbot backend endpoint (e.g. a Firebase Cloud Function or your own API)
# This should be a server endpoint that holds your OpenAI/Claude API key —
# never put an AI API key directly in frontend code.
VITE_CHATBOT_ENDPOINT=

# Zoho CRM integration
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_SCOPE=ZohoCRM.modules.ALL
ZOHO_ACCOUNT_URL=https://accounts.zoho.com
PORT=3001
